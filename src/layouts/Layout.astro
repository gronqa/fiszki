---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/fiszki/favicon.svg" />
		<link rel="icon" href="/fiszki/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Flashcards - Claude Certified Architect Foundations</title>
		<meta name="description" content="Interactive flashcards for studying the Claude Certified Architect Foundations certification exam. 300 questions with answers and explanations." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0f172a] text-slate-100 font-sans min-h-screen">
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: 'Inter', sans-serif;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Outfit', sans-serif;
	}
</style>
